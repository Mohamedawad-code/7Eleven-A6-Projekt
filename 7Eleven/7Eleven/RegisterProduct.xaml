<UserControl x:Class="_7Eleven.RegisterProduct"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:_7Eleven"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">
        <TextBlock HorizontalAlignment="Left" Margin="150,2,0,0" TextWrapping="Wrap" Text="Register product" FontWeight="Bold" FontFamily="Times New Roman"/>

        <Rectangle HorizontalAlignment="Center" Height="1" Margin="0,25,0,0" Stroke="Gray" VerticalAlignment="Top" Width="800"/>

        <Rectangle HorizontalAlignment="Left" Height="450" Margin="145,0.6,0,0" Stroke="gray" VerticalAlignment="Top" Width="1"/>
        <Button Content="Back" Click="Back_Click" FontFamily="Times New Roman" HorizontalAlignment="Left" Margin="180,350,0,0" VerticalAlignment="Top" Width="85"/>
        <Button Content="Home" Click="Home_Click" FontFamily="Times New Roman" HorizontalAlignment="Left" Margin="0,26,0,0" VerticalAlignment="Top" Height="61" Width="146"/>


        <Button Content="Register product" FontFamily="Times New Roman" HorizontalAlignment="Left" Margin="0,87,0,0" VerticalAlignment="Top" Height="62" Width="146"/>
        <Button Content="Deprecate a product" Click="DeprecationView_Click" FontFamily="Times New Roman" HorizontalAlignment="Left" Margin="0,148,0,0" VerticalAlignment="Top" Height="62" Width="146"/>
        <Rectangle HorizontalAlignment="Center" Height="1" Margin="0,85.5,0,0" Stroke="Gray" VerticalAlignment="Top" Width="800"/>
        <TextBlock HorizontalAlignment="Left" Margin="153,63,0,0" TextWrapping="Wrap" Text="Fill in the required information for registration" VerticalAlignment="Top" FontFamily="Times New Roman" Foreground="gray"/>


        <Button Content="Clear" Click="Clear_Click" HorizontalAlignment="Left" FontFamily="Times New Roman" Margin="300,350,0,0" VerticalAlignment="Top" Width="86" RenderTransformOrigin="0.629,0.476" Background="red" Foreground="white"/>
        <Button Content="Save" HorizontalAlignment="Left" FontFamily="Times New Roman" Margin="418,350,0,0" VerticalAlignment="Top" Width="86" Background="Green" Foreground="white"/>
        <TextBlock HorizontalAlignment="Left" Margin="168,110,0,0" TextWrapping="Wrap" Text="Product Name" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" Margin="168,150,0,0" TextWrapping="Wrap" Text="Category" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" Margin="168,190,0,0" TextWrapping="Wrap" Text="Amount" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" Margin="168,235,0,0" TextWrapping="Wrap" Text="Expiration Date" VerticalAlignment="Top"/>
        <TextBox x:Name="PName" HorizontalAlignment="Left" Margin="500,110,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="PCategory" HorizontalAlignment="Left" Margin="500,150,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="PAmount" HorizontalAlignment="Left" Margin="500,190,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <DatePicker x:Name="PExpirationDate" HorizontalAlignment="Left" Margin="498,230,0,0" VerticalAlignment="Top" Width="123"/>



    </Grid>
</UserControl>
