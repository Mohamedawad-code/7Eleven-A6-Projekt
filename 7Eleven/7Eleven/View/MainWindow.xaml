<Window x:Class="_7Eleven.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_7Eleven"
        mc:Ignorable="d"
        Title="7-Eleven Vare Register" Height="500" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F0">

    <Window.Resources>
        <!-- 7-Eleven colors -->
        <SolidColorBrush x:Key="SevenGreen" Color="#006B3C"/>
        <SolidColorBrush x:Key="SevenOrange" Color="#F7941D"/>
        <SolidColorBrush x:Key="SevenRed" Color="#C8102E"/>
        <SolidColorBrush x:Key="LightBg" Color="#F5F5F0"/>
        <SolidColorBrush x:Key="DarkText" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="SubText" Color="#666666"/>

        <!-- Nav button style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
                            <ContentPresenter VerticalAlignment="Center" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E8F5EE"/>
                                <Setter Property="Foreground" Value="#006B3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active nav button -->
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#E8F5EE"/>
            <Setter Property="Foreground" Value="#006B3C"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Main action button -->
        <Style x:Key="MainActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#006B3C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005530"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Background="White" 
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock FontFamily="Georgia" FontSize="20" FontWeight="Bold" VerticalAlignment="Center">
                        <Run Text="SEV" Foreground="#C8102E"/>
                        <Run Text="EN" Foreground="#F7941D"/>
                        <Run Text="-" Foreground="#F7941D"/>
                        <Run Text="ELEVEN" Foreground="#006B3C"/>
                    </TextBlock>
                    <TextBlock Text=" Vare Register" FontFamily="Georgia" FontSize="14" 
                               Foreground="#666666" VerticalAlignment="Center" Margin="4,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left sidebar -->
            <Border Grid.Column="0" Background="White" 
                    BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,20,0,0">
                    <TextBlock Text="MENU" FontFamily="Georgia" FontSize="10" 
                               Foreground="#999999" FontWeight="Bold"
                               Margin="14,0,0,12"/>

                    <Button Content="📊  Oversigt" Style="{StaticResource NavButton}"
                            Click="OverviewViewPage_Click"
                            Height="48" Width="180"/>

                    <Button Content="➕  Registrer Vare" Style="{StaticResource NavButton}"
                            Click="RegisterProductView_Click"
                            Height="48" Width="180"/>

                    <Button Content="🗑️  Afskriv Vare" Style="{StaticResource NavButton}"
                            Click="DeprecationView_Click"
                            Height="48" Width="180"/>

                    <!-- Logo at bottom -->
                    <Image Source="/icons/7-eleven-seeklogo.png" 
                           Width="80" Margin="50,40,50,0"
                           VerticalAlignment="Bottom"/>
                </StackPanel>
            </Border>

            <!-- Right content area -->
            <Border Grid.Column="1" Background="#F5F5F0">
                <ContentControl x:Name="MainContent">
                    <!-- Default home screen -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock FontFamily="Georgia" FontSize="32" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Run Text="SEV" Foreground="#C8102E"/>
                            <Run Text="EN" Foreground="#F7941D"/>
                            <Run Text="-" Foreground="#F7941D"/>
                            <Run Text="ELEVEN" Foreground="#006B3C"/>
                        </TextBlock>
                        <TextBlock Text="Vare Register System" FontFamily="Georgia" FontSize="16"
                                   Foreground="#666666" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                        <Button Content="📊  Vis Oversigt" Style="{StaticResource MainActionButton}"
                                Click="OverviewViewPage_Click"
                                Height="50" Width="220" Margin="0,0,0,12"/>

                        <Button Content="➕  Registrer Ny Vare" Style="{StaticResource MainActionButton}"
                                Click="RegisterProductView_Click"
                                Height="50" Width="220" Margin="0,0,0,12"/>

                        <Button Content="🗑️  Afskriv Vare" Height="50" Width="220"
                                Click="DeprecationView_Click"
                                FontFamily="Georgia" FontSize="16"
                                Foreground="White" Background="#C8102E" BorderThickness="0"
                                Cursor="Hand"/>
                    </StackPanel>
                </ContentControl>
            </Border>
        </Grid>
    </Grid>
</Window>
